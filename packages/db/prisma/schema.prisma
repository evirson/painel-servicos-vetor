generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProbeType {
  http_api
  db_port
  firebird
  asta
  sefaz
  ping
  tls_cert
  // Tipos alimentados por PUSH (agente no servidor), não pelo agendador.
  // O worker nunca os executa; quem grava é POST /api/ingest/agent.
  host_metric
  docker_container
}

enum CredencialTipo {
  senha
  token
  chave_ssh
  certificado
  outro
}

enum CheckStatus {
  up
  down
  degraded
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  senhaHash String
  papel     String   @default("admin")
  createdAt DateTime @default(now())
}

model StatusGroup {
  id        String    @id @default(cuid())
  nome      String
  ordem     Int       @default(0)
  targets   Target[]
  projetos  Projeto[]
  createdAt DateTime  @default(now())
}

/// Um sistema real hospedado na infra (ex.: "Portal do Representante").
/// StatusGroup é o agrupamento de APRESENTAÇÃO da página pública; Projeto é o sistema
/// em si. Os alvos monitorados podem ser derivados das URLs cadastradas aqui.
model Projeto {
  id            String       @id @default(cuid())
  nome          String
  descricao     String?
  urlFront      String?
  urlApi        String?
  host          String?
  statusGroup   StatusGroup? @relation(fields: [statusGroupId], references: [id], onDelete: SetNull)
  statusGroupId String?
  ativo         Boolean      @default(true)
  ordem         Int          @default(0)
  targets       Target[]
  credenciais   Credencial[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

/// Servidor que roda um agente reportando métricas de dentro (docker, disco, CPU).
/// Necessário porque as portas internas (bancos) ficam fechadas para a internet:
/// de fora, container e banco são invisíveis.
model Host {
  id         String    @id @default(cuid())
  nome       String
  ip         String?
  /// Hash bcrypt do token do agente — o token em claro só existe no agente.
  tokenHash  String
  lastSeenAt DateTime?
  ativo      Boolean   @default(true)
  targets    Target[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

/// Cofre de credenciais. O campo `segredo` guarda SEMPRE o texto cifrado
/// (AES-256-GCM, ver apps/worker/src/secrets.ts) — nunca o valor em texto puro.
model Credencial {
  id        String         @id @default(cuid())
  projeto   Projeto?       @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  projetoId String?
  nome      String
  tipo      CredencialTipo @default(senha)
  usuario   String?
  host      String?
  segredo   String
  notas     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model Target {
  id                String       @id @default(cuid())
  nome              String
  tipo              ProbeType
  host              String?
  porta             Int?
  url               String?
  config            Json?
  intervaloSegundos Int          @default(60)
  timeoutMs         Int          @default(5000)
  ativo             Boolean      @default(true)
  publico           Boolean      @default(true)
  statusGroup       StatusGroup? @relation(fields: [statusGroupId], references: [id], onDelete: SetNull)
  statusGroupId     String?
  projeto           Projeto?     @relation(fields: [projetoId], references: [id], onDelete: SetNull)
  projetoId         String?
  /// Servidor com agente que reporta este alvo (nulo para alvos checados de fora).
  /// Chama-se `servidor` porque `host` já é o hostname usado pelas sondas TCP.
  servidor          Host?        @relation(fields: [hostId], references: [id], onDelete: Cascade)
  hostId            String?
  /// Chave estável do item dentro do host (nome do container, ponto de montagem
  /// do disco, "cpu", "mem"). Permite reencontrar o alvo a cada relato do agente
  /// mesmo que alguém renomeie o alvo no admin.
  chaveAgente       String?
  lastStatus        CheckStatus?
  lastCheckedAt     DateTime?
  checks            Check[]
  checkDaily        CheckDaily[]
  incidents         Incident[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model Check {
  id         String      @id @default(cuid())
  target     Target      @relation(fields: [targetId], references: [id], onDelete: Cascade)
  targetId   String
  timestamp  DateTime    @default(now())
  status     CheckStatus
  latenciaMs Int?
  mensagem   String?

  @@index([targetId, timestamp])
}

/// Consolidação diária de `Check`, por alvo. Existe para que a página pública
/// não precise varrer o histórico bruto: 90 dias de um alvo são 90 linhas aqui,
/// contra ~130 mil em `Check`. Preenchida pelo job em apps/worker/src/rollup.ts.
model CheckDaily {
  id              String   @id @default(cuid())
  target          Target   @relation(fields: [targetId], references: [id], onDelete: Cascade)
  targetId        String
  dia             DateTime @db.Date
  up              Int      @default(0)
  degraded        Int      @default(0)
  down            Int      @default(0)
  total           Int      @default(0)
  latenciaMediaMs Int?

  @@unique([targetId, dia])
  @@index([dia])
}

model Incident {
  id       String    @id @default(cuid())
  target   Target    @relation(fields: [targetId], references: [id], onDelete: Cascade)
  targetId String
  inicio   DateTime  @default(now())
  fim      DateTime?
  resumo   String?

  @@index([targetId, inicio])
}
