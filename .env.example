# Banco do próprio painel (Postgres). Porta 55432 = a exposta pelo docker-compose.
DATABASE_URL=postgresql://vetor:vetor@localhost:55432/painel

# Porta da API/worker
PORT=4400

# URL da API que o navegador usa para falar com o worker
NEXT_PUBLIC_API_URL=http://localhost:4400

# Segredo para assinar os tokens JWT do admin (troque em produção!)
AUTH_SECRET=troque-este-segredo

# Chave do cofre de credenciais (AES-256-GCM). Gere com:  openssl rand -base64 32
# Sem ela o cofre fica desativado (as rotas /api/credenciais respondem 503).
# ATENÇÃO: se esta chave mudar, os segredos já gravados ficam ilegíveis.
SECRETS_KEY=

# Admin inicial criado/atualizado no boot (opcional)
ADMIN_EMAIL=admin@vetor.com.br
ADMIN_PASSWORD=troque-esta-senha

# Certificado A1 (.pfx) para as consultas SEFAZ que exigem mTLS (opcional).
# Coloque o arquivo em ./certs (ignorado pelo git) — ver certs/README.md.
# O caminho é o de DENTRO do container, onde ./certs é montado como /certs.
# NFE_CERT_PFX_PATH=/certs/vetor-a1.pfx
# NFE_CERT_PASS=senha-do-certificado
